# Optional — overrides the dashboard title shown in the top bar.
NEXT_PUBLIC_DASHBOARD_TITLE=Joaquin's Command Center

# ─────────────────────────────────────────────────────────────────────────────
# Google Sheets WRITE access (service account) — required to edit sheets in-app.
# Reads do NOT need any of this (they use the public CSV export).
#
# Copy this file to .env.local for local dev, and add the same keys in
# Vercel → Project → Settings → Environment Variables for production.
# NEVER commit real values — .env.local is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# The service account's client_email, from the downloaded JSON key.
GOOGLE_SHEETS_CLIENT_EMAIL=dashboard-writer@your-project.iam.gserviceaccount.com

# The service account's private_key, from the JSON key.
# Keep the surrounding quotes and the literal \n escapes on one line.
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...your...key...\n-----END PRIVATE KEY-----\n"

# Passcode you type in the site to unlock editing. Choose something unique —
# do not reuse a password from anywhere else. Without this, editing stays off.
EDIT_SECRET=choose-a-strong-passphrase
